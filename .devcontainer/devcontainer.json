{
	"name": "InstantSFM",
	"image": "instantsfm",
	
	// Comment out and comment "image" if you haven't built the image manually
	// "build": {
	// 		"dockerfile": "../Dockerfile",
	// 		"context": ".."
    // },

	"runArgs": [
		"--user=0:0",
		"--gpus=all",
		"--ipc=host"
	],

	"features": {
		"ghcr.io/jsburckhardt/devcontainer-features/codex:1": {}
	},

	"mounts": [
		"source=${localEnv:HOME}/.cache,target=/root/.cache,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.codex,target=/root/.codex,type=bind",
	],
	
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-toolsai.jupyter",
				"mutantdino.resourcemonitor",
				"ms-azuretools.vscode-docker",
				"nvidia.nsight-vscode-edition",
				"charliermarsh.ruff"
			]
		}
	}
}